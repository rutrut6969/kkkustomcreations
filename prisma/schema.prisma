generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

enum AvailabilityStatus {
  IN_STOCK
  LOW_STOCK
  MADE_TO_ORDER
  OUT_OF_STOCK
}

enum BlogStatus {
  PUBLISHED
  DRAFT
}

enum FulfillmentType {
  SHIPPING
  PICKUP
  DROPOFF
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  READY_FOR_PICKUP
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELED
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

enum CustomOrderStatus {
  NEW
  REVIEWING
  AWAITING_CUSTOMER
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum MediaAssetType {
  IMAGE
  DOCUMENT
  OTHER
}

enum SquareSyncStatus {
  NOT_SYNCED
  SYNCED
  PENDING
  ERROR
  SKIPPED
}

model Category {
  id             String    @id @default(cuid())
  name           String    @unique
  slug           String    @unique
  description    String?
  bannerImageUrl String?
  visible        Boolean   @default(true)
  sortOrder      Int       @default(0)
  squareCatalogId String?   @unique
  squareVersion  String?
  squareUpdatedAt DateTime?
  lastSyncedAt   DateTime?
  syncStatus     SquareSyncStatus @default(NOT_SYNCED)
  syncError      String?
  products       Product[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Product {
  id              String             @id @default(cuid())
  name            String
  slug            String             @unique
  shortDescription String?
  metaDescription String?
  description     String
  priceCents      Int
  salePriceCents  Int?
  imageUrl        String
  stock           Int                @default(0)
  availability    AvailabilityStatus @default(IN_STOCK)
  status          ProductStatus      @default(ACTIVE)
  featured        Boolean            @default(false)
  madeToOrder     Boolean            @default(false)
  tags            String[]           @default([])
  squareCatalogId String?            @unique
  squareVersion   String?
  squareUpdatedAt DateTime?
  lastSyncedAt    DateTime?
  syncStatus      SquareSyncStatus   @default(NOT_SYNCED)
  syncError       String?
  inventorySyncedAt DateTime?
  inventorySyncStatus SquareSyncStatus @default(NOT_SYNCED)
  inventorySyncError String?
  categoryId      String
  category        Category           @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  images          ProductImage[]
  variants        ProductVariant[]
  orderItems      OrderItem[]
  socialProof     SocialProofPurchase[]
  archivedAt      DateTime?
  deletedAt       DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model ProductVariant {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name        String
  value       String
  priceDeltaCents Int   @default(0)
  stock       Int?
  sku         String?
  squareCatalogId String? @unique
  squareVersion String?
  lastSyncedAt DateTime?
  syncStatus SquareSyncStatus @default(NOT_SYNCED)
  syncError String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  address1  String?
  city      String?
  state     String?
  postalCode String?
  country   String?  @default("US")
  marketingConsent Boolean @default(false)
  orderConsent     Boolean @default(false)
  lastOrderAt      DateTime?
  totalSpentCents  Int     @default(0)
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id              String          @id @default(cuid())
  orderNumber     String          @unique
  customerId      String?
  customer        Customer?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerName    String
  customerEmail   String?
  customerPhone   String?
  fulfillmentType FulfillmentType
  paymentStatus   PaymentStatus   @default(PENDING)
  status          OrderStatus     @default(PENDING)
  subtotalCents   Int             @default(0)
  totalCents      Int             @default(0)
  notes           String?
  internalNotes   String?
  squareOrderId   String?
  squarePaymentId String?
  squareVersion   String?
  squareUpdatedAt DateTime?
  lastSyncedAt    DateTime?
  syncStatus      SquareSyncStatus @default(NOT_SYNCED)
  syncError       String?
  inventoryAdjustedAt DateTime?
  inventoryAdjustmentStatus SquareSyncStatus @default(NOT_SYNCED)
  inventoryAdjustmentError String?
  webhookProcessedAt DateTime?
  idempotencyKey  String?         @unique
  address1        String?
  city            String?
  state           String?
  postalCode      String?
  items           OrderItem[]
  archivedAt      DateTime?
  deletedAt       DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productName String
  quantity    Int
  unitPriceCents Int
  totalCents  Int
  customizationNotes String?
  createdAt   DateTime @default(now())
}

model Event {
  id                String   @id @default(cuid())
  title             String
  date              DateTime
  time              String
  location          String
  description       String
  facebookEventLink String?
  featured          Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model BlogPost {
  id             String     @id @default(cuid())
  title          String
  slug           String     @unique
  excerpt        String
  body           String
  publishedDate  DateTime
  featuredImage  String?
  status         BlogStatus @default(DRAFT)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  body      String
  active    Boolean  @default(true)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CustomOrderRequest {
  id             String   @id @default(cuid())
  name           String
  email          String
  phone          String
  itemType       String
  designRequest  String
  neededBy       DateTime?
  imageNote      String?
  consent        Boolean
  status         CustomOrderStatus @default(NEW)
  internalNotes  String?
  imageUrl       String?
  archived       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ContactMessage {
  id               String   @id @default(cuid())
  name             String
  email            String
  phone            String?
  message          String
  consent          Boolean
  marketingConsent Boolean  @default(false)
  createdAt        DateTime @default(now())
}

model SocialProofPurchase {
  id           String   @id @default(cuid())
  customerName String
  productName  String
  productId    String?
  product      Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  fallbackUrl  String?
  isSample     Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model MediaAsset {
  id          String         @id @default(cuid())
  fileName    String
  url         String
  altText     String?
  assetType   MediaAssetType @default(IMAGE)
  mimeType    String?
  sizeBytes   Int?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model SquareSyncLog {
  id        String           @id @default(cuid())
  action    String
  status    SquareSyncStatus
  message   String?
  metadata  Json?
  createdAt DateTime         @default(now())
}

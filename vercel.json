{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm install",
  "buildCommand": "npm run prisma:deploy && npm run build",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/square-sync",
      "schedule": "0 3 * * *"
    }
  ]
}
